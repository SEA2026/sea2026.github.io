---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import fs from 'node:fs/promises'

const content = await fs.readFile('./src/data/accepted.jsonl', 'utf-8')
const papers = content
  .trim()
  .split('\n')
  .map((line) => JSON.parse(line))
---

<DefaultLayout title="Accepted papers">
  <section class="mb-20">
    <div class="container flex flex-col gap-4">
      <h1>Accepted papers</h1>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr class="border-b-2 border-gray-300">
              <th class="w-12 px-2 py-3 font-semibold text-center">#</th>
              <th class="px-4 py-3 font-semibold">Title</th>
              <th class="px-4 py-3 font-semibold">Authors</th>
            </tr>
          </thead>
          <tbody>
            {
              papers.map((paper, i) => (
                <tr class="border-b border-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800">
                  <td class="text-muted px-2 py-3 text-center">{i + 1}</td>
                  <td class="px-4 py-3 font-medium">{paper.title}</td>
                  <td class="text-muted px-4 py-3">{paper.authors.join(', ')}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>
</DefaultLayout>
