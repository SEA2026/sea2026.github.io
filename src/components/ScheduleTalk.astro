---
import fs from 'node:fs/promises'

interface Props {
  id: number
  time: string
  index: number
}

const { id, time, index } = Astro.props

const content = await fs.readFile('./src/data/accepted.jsonl', 'utf-8')
const papers = content.trim().split('\n').map((line) => JSON.parse(line))
const paper = papers.find((p: { id: number }) => p.id === id)
---

{
  paper && (
    <div class={`flex items-baseline gap-3 py-2 ${index % 2 === 0 ? 'bg-gray-50 dark:bg-white/5' : ''}`}>
      <span class="shrink-0 w-14 text-sm tabular-nums opacity-60 whitespace-nowrap text-right">{time}</span>
      <div>
        <p class="text-sm font-medium leading-snug m-0">{paper.title}</p>
        <p class="text-xs opacity-60 mt-0.5 leading-snug m-0">{paper.authors.join(', ')}</p>
      </div>
    </div>
  )
}
