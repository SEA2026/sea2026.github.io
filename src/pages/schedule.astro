---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import ScheduleTalk from '@components/ScheduleTalk.astro'

const MINS_PER_TALK = 25

function parseMinutes(hhmm: string): number {
  const [h, m] = hhmm.split(':').map(Number)
  return h * 60 + m
}

function addMinutes(hhmm: string, mins: number): string {
  const total = parseMinutes(hhmm) + mins
  const h = Math.floor(total / 60)
  const m = total % 60
  return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`
}

const days = [
  {
    date: 'Monday, June 22, 2026',
    dateKey: '2026-06-22',
    slots: [
      { time: '09:00–09:15', label: 'Opening & Welcome 🎉', type: 'special' },
      { time: '09:15–10:15', label: 'Invited Talk 1', speaker: 'Charalampos E. Tsourakakis', speakerHref: '/speakers#speaker-charalampos-e-tsourakakis', subtitle: 'Algorithmic Primitives for Finding Dense Structures in Rich Graph Data', type: 'invited' },
      { time: '10:15–10:45', label: 'Coffee break ☕', type: 'break' },
      { time: '10:45–12:25', label: 'Session 1', name: 'Optimization and network design', type: 'session', talks: [2, 3, 14, 26] },
      { time: '12:30–14:00', label: 'Lunch 🍽️', type: 'break' },
      { time: '14:00–15:15', label: 'Session 2', name: 'Compression', type: 'session', talks: [8, 13, 19] },
      { time: '15:15–15:45', label: 'Coffee break ☕', type: 'break' },
      { time: '15:45–17:00', label: 'Session 3', name: 'Practical and parallel algorithm engineering', type: 'session', talks: [11, 17, 24] },
    ],
  },
  {
    date: 'Tuesday, June 23, 2026',
    dateKey: '2026-06-23',
    slots: [
      { time: '09:00–10:00', label: 'Invited Talk 2', speaker: 'Inge Li Gørtz', speakerHref: '/speakers#speaker-inge-li-gortz', subtitle: 'Locality Sensitive Hashing and Compressed Computation', type: 'invited' },
      { time: '10:00–10:30', label: 'Coffee break ☕', type: 'break' },
      { time: '10:30–12:10', label: 'Session 4', name: 'Geometry', type: 'session', talks: [15, 1, 21, 9] },
      { time: '12:30–14:00', label: 'Lunch 🍽️', type: 'break' },
      { time: '14:00–15:40', label: 'Session 5', name: 'Data structures', type: 'session', talks: [5, 18, 25, 27] },
      { time: '17:00–19:00', label: 'Conference dinner 🍷 (at conference venue)', type: 'social' },
      { time: '19:00–23:00', label: 'Excursion to Sankt Hans 🔥', type: 'social' },
    ],
  },
  {
    date: 'Wednesday, June 24, 2026',
    dateKey: '2026-06-24',
    slots: [
      { time: '08:45–09:45', label: 'Invited Talk 3', speaker: 'Sebastian Wild', speakerHref: '/speakers#speaker-sebastian-wild', subtitle: 'Adaptive Sorting and Searching from Theory to Practice', type: 'invited' },
      { time: '09:45–10:15', label: 'Coffee break ☕', type: 'break' },
      { time: '10:15–11:30', label: 'Session 6', name: 'Integer programming and combinatorial optimization', type: 'session', talks: [4, 22, 23] },
      { time: '11:30–13:00', label: 'Lunch 🍽️', type: 'break' },
      { time: '13:00–14:40', label: 'Session 7', name: 'Graph algorithms', type: 'session', talks: [7, 12, 16, 20] },
      { time: '14:40–15:10', label: 'Coffee break ☕', type: 'break' },
      { time: '15:10–16:25', label: 'Session 8', name: 'Hashing, filters, and combinatorial structures', type: 'session', talks: [6, 10, 28] },
      { time: '16:30–17:30', label: 'SEA Business Meeting 📋', type: 'special' },
    ],
  },
]

for (const day of days) {
  for (const slot of day.slots) {
    if ('talks' in slot) {
      const [startStr, endStr] = slot.time.split('–')
      const duration = parseMinutes(endStr) - parseMinutes(startStr)
      const expected = slot.talks.length * MINS_PER_TALK
      if (duration !== expected) {
        throw new Error(
          `Schedule mismatch — ${slot.label} (${day.date}): ` +
          `${duration} min slot ≠ ${slot.talks.length} talks × ${MINS_PER_TALK} min = ${expected} min`
        )
      }
    }
  }
}

function nonTalkAttrs(dateKey: string, time: string): Record<string, string> {
  const parts = time.split('–')
  if (parts.length !== 2) return {}
  return {
    'data-start': `${dateKey}T${parts[0]}+02:00`,
    'data-end': `${dateKey}T${parts[1]}+02:00`,
  }
}

const labelClass: Record<string, string> = {
  invited: 'text-base font-bold',
  special: 'text-base font-semibold',
  social: 'text-base',
  break: 'text-base',
  session: 'text-base',
}

const rowBgClass: Record<string, string> = {}

const rowBorderClass: Record<string, string> = {}
---

<DefaultLayout title="Schedule">
  <section class="mb-20">
    <div class="container flex flex-col gap-8">
      <h1>Schedule</h1>
      <p class="text-muted italic">The schedule is preliminary and subject to change.</p>

      {days.map((day) => (
        <div class="flex flex-col gap-4">
          <h2 class="text-lg font-bold border-b-2 border-gray-300 dark:border-gray-600 pb-1 mb-1">{day.date}</h2>

          {day.slots.map((slot) =>
            'talks' in slot ? (
              <div class="rounded">
                <div class="flex items-baseline gap-3 mb-1">
                  <span class="shrink-0 w-14" />
                  <span class="text-base font-bold"><span class="bg-[var(--color-primary-100)] dark:bg-[var(--color-primary-400)]/40 rounded px-1">{slot.label}</span><span class="font-medium"> · {slot.name}</span></span>
                </div>
                {slot.talks.map((id, i) => {
                  const start = addMinutes(slot.time.split('–')[0], i * MINS_PER_TALK)
                  return <ScheduleTalk id={id} time={start} dateKey={day.dateKey} />
                })}
              </div>
            ) : (
              <div {...nonTalkAttrs(day.dateKey, slot.time)} class={`flex items-baseline gap-3 py-1 rounded ${rowBgClass[slot.type] ?? ''} ${rowBorderClass[slot.type] ?? ''}`}>
                <span class="shrink-0 w-14 text-sm tabular-nums opacity-60 whitespace-nowrap text-right relative">
                  {slot.time.split('–')[0]}
                  <span class="live-dot" aria-hidden="true" />
                </span>
                <div>
                  <p class={`m-0 leading-snug ${labelClass[slot.type] ?? 'text-sm'}`}>
                    {slot.type === 'invited'
                      ? <span class="bg-[var(--color-secondary-100)] dark:bg-[var(--color-secondary-400)]/40 rounded px-1">{slot.label}</span>
                      : slot.label}
                    {'speaker' in slot && slot.speaker && (
                      <> · {slot.speaker}</>
                    )}
                  </p>
                  {'subtitle' in slot && slot.subtitle && (
                    <p class="text-base font-medium mt-0.5 m-0 leading-snug">
                      {slot.subtitle}
                      {'speakerHref' in slot && slot.speakerHref && (
                        <> · <a href={slot.speakerHref} data-astro-reload class="ml-0.5 text-xs font-normal opacity-35 hover:opacity-65 transition-opacity whitespace-nowrap" style="color:inherit;text-decoration:none">[more]</a></>
                      )}
                    </p>
                  )}
                </div>
              </div>
            )
          )}
        </div>
      ))}
    </div>
  </section>
</DefaultLayout>

