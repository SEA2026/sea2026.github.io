---
import { Image } from 'astro:assets'
import logo from '../assets/img/SEA2026-logo.png'
import fs from 'node:fs/promises'
import '../styles/tailwind.css'
import '../assets/scss/index.scss'

const MINS_PER_SLOT = 25
const MINS_PER_TALK = 20

function addMinutes(hhmm: string, mins: number): string {
  const [h, m] = hhmm.split(':').map(Number)
  const total = h * 60 + m + mins
  return `${String(Math.floor(total / 60)).padStart(2, '0')}:${String(total % 60).padStart(2, '0')}`
}

interface SessionSlot { time: string; label: string; type: 'session'; name: string; talks: number[]; chair: string }
interface InvitedSlot { time: string; label: string; type: 'invited'; speaker: string; speakerHref?: string; subtitle: string }
interface OtherSlot  { time: string; label: string; type: 'special' | 'break' | 'social' }
type Slot = SessionSlot | InvitedSlot | OtherSlot

const days: { date: string; dateKey: string; slots: Slot[] }[] = [
  {
    date: 'Monday, June 22, 2026',
    dateKey: '2026-06-22',
    slots: [
      { time: '09:00–09:15', label: 'Opening & Welcome', type: 'special' },
      { time: '09:15–10:15', label: 'Invited Talk 1', type: 'invited', speaker: 'Charalampos E. Tsourakakis', speakerHref: '/speakers#speaker-charalampos-e-tsourakakis', subtitle: 'Algorithmic Primitives for Finding Dense Structures in Rich Graph Data' },
      { time: '10:15–10:45', label: 'Coffee break', type: 'break' },
      { time: '10:45–12:25', label: 'Session 1', type: 'session', name: 'Optimization and network design', talks: [2, 3, 14, 26], chair: 'TBD' },
      { time: '12:30–14:00', label: 'Lunch', type: 'break' },
      { time: '14:00–15:15', label: 'Session 2', type: 'session', name: 'Compression', talks: [8, 13, 19], chair: 'Hideo Bannai' },
      { time: '15:15–15:45', label: 'Coffee break', type: 'break' },
      { time: '15:45–17:00', label: 'Session 3', type: 'session', name: 'Practical and parallel algorithm engineering', talks: [11, 17, 24], chair: 'TBD' },
    ],
  },
  {
    date: 'Tuesday, June 23, 2026',
    dateKey: '2026-06-23',
    slots: [
      { time: '09:00–10:00', label: 'Invited Talk 2', type: 'invited', speaker: 'Inge Li Gørtz', speakerHref: '/speakers#speaker-inge-li-gortz', subtitle: 'Locality Sensitive Hashing and Compressed Computation' },
      { time: '10:00–10:30', label: 'Coffee break', type: 'break' },
      { time: '10:30–12:10', label: 'Session 4', type: 'session', name: 'Geometry', talks: [15, 1, 21, 9], chair: 'Sarita de Berg' },
      { time: '12:30–14:00', label: 'Lunch', type: 'break' },
      { time: '14:00–15:40', label: 'Session 5', type: 'session', name: 'Data structures', talks: [5, 18, 25, 27], chair: 'Philip Bille' },
      { time: '17:00–19:00', label: 'Conference dinner (at conference venue)', type: 'social' },
      { time: '19:00–23:00', label: 'Excursion to Sankt Hans', type: 'social' },
    ],
  },
  {
    date: 'Wednesday, June 24, 2026',
    dateKey: '2026-06-24',
    slots: [
      { time: '08:45–09:45', label: 'Invited Talk 3', type: 'invited', speaker: 'Sebastian Wild', speakerHref: '/speakers#speaker-sebastian-wild', subtitle: 'Adaptive Sorting and Searching from Theory to Practice' },
      { time: '09:45–10:15', label: 'Coffee break', type: 'break' },
      { time: '10:15–11:30', label: 'Session 6', type: 'session', name: 'Integer programming and combinatorial optimization', talks: [4, 22, 23], chair: 'Jon Lee' },
      { time: '11:30–13:00', label: 'Lunch', type: 'break' },
      { time: '13:00–14:40', label: 'Session 7', type: 'session', name: 'Graph algorithms', talks: [7, 12, 16, 20], chair: 'Ivor van der Hoog' },
      { time: '14:40–15:10', label: 'Coffee break', type: 'break' },
      { time: '15:10–16:25', label: 'Session 8', type: 'session', name: 'Hashing, filters, and combinatorial structures', talks: [6, 10, 28], chair: 'Manuel Penschuk' },
      { time: '16:30–17:30', label: 'SEA Business Meeting', type: 'special' },
    ],
  },
]

const rawContent = await fs.readFile('./src/data/accepted.jsonl', 'utf-8')
const papers: Record<number, { title: string; authors: string[] }> = {}
for (const line of rawContent.trim().split('\n')) {
  const p = JSON.parse(line)
  papers[p.id] = { title: p.title, authors: p.authors }
}

type NowEvent =
  | { type: 'talk'; start: string; end: string; session: { label: string; name: string; chair: string }; paper: { title: string; authors: string[] } }
  | { type: 'invited'; start: string; end: string; label: string; speaker: string; subtitle: string }
  | { type: string; start: string; end: string; label: string }

const events: NowEvent[] = []
for (const day of days) {
  for (const slot of day.slots) {
    if (slot.type === 'session') {
      const s = slot as SessionSlot
      for (let i = 0; i < s.talks.length; i++) {
        const startStr = addMinutes(s.time.split('–')[0], i * MINS_PER_SLOT)
        const endStr = addMinutes(startStr, MINS_PER_TALK)
        events.push({
          type: 'talk',
          start: `${day.dateKey}T${startStr}+02:00`,
          end: `${day.dateKey}T${endStr}+02:00`,
          session: { label: s.label, name: s.name, chair: s.chair },
          paper: papers[s.talks[i]],
        })
      }
    } else if (slot.type === 'invited') {
      const s = slot as InvitedSlot
      const [startStr, endStr] = s.time.split('–')
      events.push({ type: 'invited', start: `${day.dateKey}T${startStr}+02:00`, end: `${day.dateKey}T${endStr}+02:00`, label: s.label, speaker: s.speaker, subtitle: s.subtitle })
    } else {
      const [startStr, endStr] = slot.time.split('–')
      events.push({ type: slot.type, start: `${day.dateKey}T${startStr}+02:00`, end: `${day.dateKey}T${endStr}+02:00`, label: slot.label })
    }
  }
}

const eventsJson = JSON.stringify(events)
---

<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Now — SEA 2026</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const dm = localStorage.getItem('darkMode')
      if (dm === 'enabled' || (!dm && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('darkmode')
        document.documentElement.style.colorScheme = 'dark'
      }
    </script>
  </head>
  <body>
    <div class="flex flex-col w-full min-h-dvh bg-[var(--background-color)] text-[var(--foreground-color)]">
      <div class="flex items-center w-full px-5 py-3 border-b border-[var(--border-color-subtle)] shrink-0">
        <a href="/" class="flex items-center gap-2.5 font-bold text-[length:var(--font-size-1)] !text-[var(--foreground-color)] no-underline">
          <Image src={logo} alt="SEA Logo" width="36" height="28" loading="eager" />
          <span>SEA 2026</span>
        </a>
        <div class="flex items-center gap-2 ml-auto">
          <button id="dm-btn" aria-label="Toggle dark mode" title="Toggle dark mode" class="flex items-center justify-center bg-transparent border-0 cursor-pointer text-[var(--foreground-color)] opacity-60 p-1.5 rounded hover:opacity-100 transition-opacity duration-150">
            <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </button>
          <button id="fs-btn" aria-label="Toggle fullscreen" title="Toggle fullscreen" class="flex items-center justify-center bg-transparent border-0 cursor-pointer text-[var(--foreground-color)] opacity-60 p-1.5 rounded hover:opacity-100 transition-opacity duration-150">
            <svg id="icon-expand" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
            <svg id="icon-compress" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/></svg>
          </button>
        </div>
      </div>

      <main id="now-main" class="flex-1 flex flex-col px-8 py-4">
        <div class="flex-1 flex items-center justify-center">
          <div id="now-content" class="w-full"></div>
        </div>
        <div id="now-timer" class="text-center pb-2"></div>
      </main>
    </div>

    <script define:vars={{ eventsJson }}>
      const events = JSON.parse(eventsJson)

      function interesting(e) {
        return e.type === 'talk' || e.type === 'invited'
      }

      function findState(now) {
        const ts = now.getTime()
        const current = events.find(e => interesting(e) && new Date(e.start).getTime() <= ts && ts < new Date(e.end).getTime())
        if (current) return { mode: 'current', event: current }
        const next = events
          .filter(e => interesting(e) && new Date(e.start).getTime() > ts)
          .sort((a, b) => new Date(a.start).getTime() - new Date(b.start).getTime())[0]
        if (next) return { mode: 'next', event: next }
        return null
      }

      function fmt(ms) {
        const s = Math.floor(ms / 1000)
        const m = Math.floor(s / 60)
        const h = Math.floor(m / 60)
        if (h > 0) return `${h}h ${String(m % 60).padStart(2, '0')}m`
        if (m > 0) return `${m}m ${String(s % 60).padStart(2, '0')}s`
        return `${s}s`
      }

      function esc(str) {
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
      }

      function sessionMeta(e) {
        const s = e.session
        let out = `<span class="font-semibold text-[var(--color-primary-400)]">${esc(s.label)}</span> <span class="opacity-50">·</span> ${esc(s.name)}`
        if (s.chair && s.chair !== 'TBD') out += ` <span class="opacity-50">·</span> Chair: ${esc(s.chair)}`
        return out
      }

      function render(now = new Date()) {
        const state = findState(now)
        const el = document.getElementById('now-content')
        if (!el) return

        const timerEl = document.getElementById('now-timer')

        if (!state) {
          el.innerHTML = '<p class="text-[length:var(--font-size-2)] opacity-60 text-center">Conference has ended. Thank you for coming!</p>'
          if (timerEl) timerEl.innerHTML = ''
          return
        }

        const e = state.event
        const mode = state.mode
        const badgeClass = 'text-[length:var(--font-size-1)] font-bold tracking-[0.08em] uppercase text-[var(--color-secondary-400)]'

        if (mode === 'current') {
          const remaining = new Date(e.end).getTime() - now.getTime()
          if (e.type === 'talk') {
            el.innerHTML = `
              <div class="${badgeClass} mb-2 leading-snug">${sessionMeta(e)}</div>
              <div class="text-[length:var(--font-size-6)] font-bold leading-[1.1] mb-1.5">${esc(e.paper.title)}</div>
              <div class="text-[length:var(--font-size-6)] font-normal opacity-75 leading-[1.3]">${esc(e.paper.authors.join(', '))}</div>
            `
          } else {
            el.innerHTML = `
              <div class="${badgeClass} mb-2 leading-snug">${esc(e.label)}</div>
              <div class="text-[length:var(--font-size-6)] font-bold leading-[1.1] mb-1.5">${esc(e.subtitle)}</div>
              <div class="text-[length:var(--font-size-6)] font-normal opacity-75 leading-[1.3]">${esc(e.speaker)}</div>
            `
          }
          if (timerEl) timerEl.innerHTML = `<span class="text-[length:var(--font-size-2)] opacity-[0.55]">ends in <span class="tabular-nums font-semibold">${fmt(remaining)}</span></span>`
        } else {
          const until = new Date(e.start).getTime() - now.getTime()
          if (e.type === 'talk') {
            el.innerHTML = `
              <div class="${badgeClass} mb-2 leading-snug">Next up · ${sessionMeta(e)}</div>
              <div class="text-[length:var(--font-size-6)] font-bold leading-[1.1] mb-1.5">${esc(e.paper.title)}</div>
              <div class="text-[length:var(--font-size-6)] font-normal opacity-75 leading-[1.3]">${esc(e.paper.authors.join(', '))}</div>
            `
          } else {
            el.innerHTML = `
              <div class="${badgeClass} mb-2 leading-snug">Next up · ${esc(e.label)}</div>
              <div class="text-[length:var(--font-size-6)] font-bold leading-[1.1] mb-1.5">${esc(e.subtitle)}</div>
              <div class="text-[length:var(--font-size-6)] font-normal opacity-75 leading-[1.3]">${esc(e.speaker)}</div>
            `
          }
          if (timerEl) timerEl.innerHTML = `<span class="text-[length:var(--font-size-2)] opacity-[0.55]">in <span class="tabular-nums font-semibold">${fmt(until)}</span></span>`
        }
      }

      // Update just the timer value without full re-render
      let lastState = null
      function tick() {
        if (testIdx !== null) return
        const now = new Date()
        const state = findState(now)
        const stateKey = state ? `${state.mode}:${state.event.start}` : 'none'
        if (stateKey !== lastState) {
          lastState = stateKey
          render()
        } else {
          const el = document.querySelector('#now-timer .tabular-nums')
          if (el && state) {
            const ref = state.mode === 'current' ? new Date(state.event.end) : new Date(state.event.start)
            el.textContent = fmt(ref.getTime() - now.getTime())
          }
        }
      }

      // Test mode: left/right arrow steps through interesting event starts
      const testSteps = events
        .filter(interesting)
        .flatMap(e => [
          { label: `next up → ${e.type === 'talk' ? e.session.label : e.label}`, t: new Date(new Date(e.start).getTime() - 60_000) },
          { label: `current → ${e.type === 'talk' ? e.session.label : e.label}`, t: new Date(new Date(e.start).getTime() + 1_000) },
        ])
      let testIdx = null

      function applyTest() {
        const step = testSteps[testIdx]
        document.title = `[${testIdx + 1}/${testSteps.length}] ${step.label}`
        lastState = null
        render(step.t)
      }

      document.addEventListener('keydown', e => {
        if (e.key === 'ArrowRight') {
          testIdx = testIdx === null ? 0 : Math.min(testIdx + 1, testSteps.length - 1)
          applyTest()
        } else if (e.key === 'ArrowLeft') {
          if (testIdx === null) return
          testIdx = testIdx === 0 ? null : testIdx - 1
          if (testIdx === null) { document.title = 'Now — SEA 2026'; lastState = null; render() }
          else applyTest()
        }
      })

      render()
      setInterval(tick, 500)

      // Fullscreen
      const fsBtn = document.getElementById('fs-btn')
      const iconExpand = document.getElementById('icon-expand')
      const iconCompress = document.getElementById('icon-compress')
      function updateFsIcons() {
        const active = !!document.fullscreenElement
        iconExpand.style.display = active ? 'none' : ''
        iconCompress.style.display = active ? '' : 'none'
      }
      fsBtn.addEventListener('click', () => {
        if (!document.fullscreenElement) {
          document.documentElement.requestFullscreen()
        } else {
          document.exitFullscreen()
        }
      })
      document.addEventListener('fullscreenchange', updateFsIcons)

      // Dark mode
      const dmBtn = document.getElementById('dm-btn')
      const iconMoon = document.getElementById('icon-moon')
      const iconSun = document.getElementById('icon-sun')
      function updateDmIcons() {
        const dark = document.documentElement.classList.contains('darkmode')
        iconMoon.style.display = dark ? 'none' : ''
        iconSun.style.display = dark ? '' : 'none'
      }
      updateDmIcons()
      dmBtn.addEventListener('click', () => {
        const dark = document.documentElement.classList.toggle('darkmode')
        document.documentElement.style.colorScheme = dark ? 'dark' : 'light'
        localStorage.setItem('darkMode', dark ? 'enabled' : 'disabled')
        updateDmIcons()
      })
    </script>
  </body>
</html>
